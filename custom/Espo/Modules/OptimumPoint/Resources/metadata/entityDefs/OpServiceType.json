{
    "fields": {
        "name": {
            "type": "varchar",
            "required": true,
            "pattern": "$noBadCharacters"
        },
        "serviceCategory": {
            "type": "link",
            "required": true
        },
        "isActive": {
            "type": "bool",
            "default": true
        },
        "sortOrder": {
            "type": "int",
            "default": 0
        },
        "description": {
            "type": "text"
        },
        "createdAt": {
            "type": "datetime",
            "readOnly": true
        },
        "modifiedAt": {
            "type": "datetime",
            "readOnly": true
        },
        "createdBy": {
            "type": "link",
            "readOnly": true
        },
        "modifiedBy": {
            "type": "link",
            "readOnly": true
        }
    },
    "links": {
        "serviceCategory": {
            "type": "belongsTo",
            "entity": "OpServiceCategory"
        },
        "createdBy": {
            "type": "belongsTo",
            "entity": "User"
        },
        "modifiedBy": {
            "type": "belongsTo",
            "entity": "User"
        }
    },
    "collection": {
        "orderBy": "sortOrder",
        "order": "asc",
        "textFilterFields": [
            "name"
        ]
    }
}
